# Copy this file to .env (same folder) and fill in your real values.
# .env is loaded automatically by database/db.py, generator/generate.py,
# and consumer/consumer.py — no need to set these in every terminal manually.

# Your MongoDB Atlas connection string (see Atlas -> Connect -> Drivers).
# Leave unset to fall back to a local MongoDB at mongodb://localhost:27017/
MONGO_URI=mongodb+srv://soc_admin:YOUR_PASSWORD@mini-soc-cluster.vua4mit.mongodb.net/?appName=mini-soc-cluster

# RabbitMQ connection string. Leave unset if using a local install with
# default guest/guest credentials — the code already defaults to that.
# Only needed if using CloudAMQP or a non-default local setup.
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2F
